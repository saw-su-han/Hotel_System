// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  name      String?
  password  String
  role      Role?   @relation(fields: [roleId], references: [id])
  roleId    Int?
  isDeleted Boolean @default(false)

  bookings Bookings[]
}

model Permission {
  id          Int              @id @default(autoincrement())
  action      String           @unique
  description String?
  roles       RolePermission[]
  isDeleted   Boolean          @default(false)

  @@map("permissions")
}

model Role {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  rolePermissions RolePermission[]
  users           User[]
  isDeleted       Boolean          @default(false)

  @@map("roles")
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  isDeleted    Boolean    @default(false)

  @@map("role_permission")
}

model Customers {
  id        Int     @id @default(autoincrement())
  name      String
  email     String  @unique
  phone     String  @unique
  isDeleted Boolean @default(false)
  nrcFront  String  @unique
  nrcBack   String  @unique

  bookings Bookings[]
}

model Rooms {
  id         Int    @id @default(autoincrement())
  roomNumber String @unique

  isDeleted Boolean @default(false)

  roomTypeId Int
  roomType   roomtypes @relation(fields: [roomTypeId], references: [id])

  bookingRooms BookingRoom[]
}

model Bookings {
  id Int @id @default(autoincrement())

  customerId Int
  customer   Customers @relation(fields: [customerId], references: [id])

  userId    Int
  user      User    @relation(fields: [userId], references: [id])
  isDeleted Boolean @default(false)

  checkInDate  DateTime
  checkOutDate DateTime

  bookingRooms BookingRoom[]
}

model BookingRoom {
  id Int @id @default(autoincrement())

  bookingId Int
  roomId    Int
  isDeleted Boolean @default(false)

  booking   Bookings    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  room      Rooms       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomTypes roomtypes[]

  @@unique([bookingId, roomId])
}

model Payments {
  id            Int      @id @default(autoincrement())
  bookingId     Int
  amount        Float
  paymentDate   DateTime @default(now())
  paymentMethod String
  isDeleted     Boolean  @default(false)
}

model roomtypes {
  id          Int    @id @default(autoincrement())
  roomType    String @unique
  price       Float
  description String
  imageUrl    String
  size        String
  bathType    String
  viewType    String

  isDeleted Boolean @default(false)

  rooms Rooms[]

  bookingRooms BookingRoom[]
}
